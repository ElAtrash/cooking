<div class="min-h-screen bg-gray-50">
  <!-- Header -->
  <div class="bg-white shadow-sm border-b border-gray-200">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">Create New Recipe</h1>
          <p class="mt-1 text-sm text-gray-600">Share your culinary creation with the community</p>
        </div>
        <%= link_to recipes_path,
            class: "text-gray-500 hover:text-gray-700 transition-colors" do %>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Form -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div id="recipe_form">
      <%= render 'form', recipe: @recipe %>
    </div>
  </div>
</div>
