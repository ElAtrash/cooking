<div id="recipes" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
  <%= render partial: 'recipe_card', collection: recipes, as: :recipe %>
</div>

<!-- Pagination -->
<% if pagy&.pages && pagy.pages > 1 %>
  <div class="mt-8 flex justify-center">
    <%= raw pagy_nav(pagy) %>
  </div>
<% end %>

<!-- Empty State -->
<% if recipes.empty? %>
  <div class="text-center py-12 col-span-full">
    <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
    </svg>
    <h3 class="mt-2 text-sm font-medium text-gray-900">No recipes found</h3>
    <p class="mt-1 text-sm text-gray-500">Try adjusting your search filters.</p>
  </div>
<% end %>
