<div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow duration-200"
     id="<%= dom_id(recipe) %>">

  <!-- Recipe Image -->
  <div class="relative h-48 bg-gray-200">
    <% if recipe.image.attached? %>
      <%= image_tag recipe.image,
          class: "w-full h-full object-cover",
          alt: recipe.title %>
    <% else %>
      <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-gray-100 to-gray-200">
        <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    <% end %>

    <!-- Difficulty Badge -->
    <div class="absolute top-3 left-3">
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= recipe.difficulty_badge_class %>">
        <%= recipe.difficulty_level.capitalize %>
      </span>
    </div>

    <!-- Favorite Button (if user is authenticated) -->
    <% if current_user %>
      <div class="absolute top-3 right-3" id="favorite_button_<%= recipe.id %>">
        <%= render 'shared/favorite_button', recipe: recipe, favorited: recipe.favorited_by?(current_user) %>
      </div>
    <% end %>
  </div>

  <!-- Recipe Content -->
  <div class="p-4">
    <!-- Title and Author -->
    <div class="mb-2">
      <%= link_to recipe_path(recipe),
          class: "text-lg font-semibold text-gray-900 hover:text-indigo-600 transition-colors" do %>
        <%= recipe.title %>
      <% end %>
      <p class="text-sm text-gray-500 mt-1">
        by <%= recipe.user.email_address %>
      </p>
    </div>

    <!-- Description -->
    <p class="text-gray-600 text-sm mb-3 line-clamp-2">
      <%= recipe.description %>
    </p>

    <!-- Recipe Stats -->
    <div class="flex items-center justify-between text-sm text-gray-500 mb-3">
      <div class="flex items-center space-x-4">
        <!-- Prep + Cook Time -->
        <div class="flex items-center">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <%= recipe.total_time %> min
        </div>

        <!-- Servings -->
        <div class="flex items-center">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          <%= pluralize(recipe.servings, 'serving') %>
        </div>
      </div>
    </div>

    <!-- Rating and Interaction Stats -->
    <div class="flex items-center justify-between">
      <div class="flex items-center space-x-3">
        <!-- Average Rating -->
        <% if recipe.recipe_ratings_count > 0 %>
          <div class="flex items-center">
            <div class="flex items-center">
              <% (1..5).each do |star| %>
                <svg class="w-4 h-4 <%= recipe.average_rating >= star ? 'text-yellow-400' : 'text-gray-300' %>"
                     fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              <% end %>
            </div>
            <span class="ml-1 text-sm text-gray-600">
              <%= recipe.average_rating %> (<%= recipe.recipe_ratings_count %>)
            </span>
          </div>
        <% else %>
          <span class="text-sm text-gray-400">No ratings yet</span>
        <% end %>
      </div>

      <!-- Action Buttons for Owner -->
      <% if current_user == recipe.user %>
        <div class="flex items-center space-x-2">
          <%= link_to edit_recipe_path(recipe),
              class: "text-indigo-600 hover:text-indigo-900 transition-colors",
              title: "Edit recipe" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
          <% end %>

          <%= link_to recipe_path(recipe),
              method: :delete,
              data: {
                confirm: "Are you sure you want to delete this recipe?",
                turbo_method: :delete
              },
              class: "text-red-600 hover:text-red-900 transition-colors",
              title: "Delete recipe" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
            </svg>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Quick Stats Footer -->
    <div class="mt-3 pt-3 border-t border-gray-100 flex items-center justify-between text-xs text-gray-500">
      <div class="flex items-center space-x-3">
        <span class="flex items-center">
          <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
          </svg>
          <%= recipe.favorite_recipes_count %>
        </span>

        <span class="flex items-center">
          <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
          <%= recipe.views_count %>
        </span>
      </div>

      <time class="text-gray-400" datetime="<%= recipe.created_at.iso8601 %>">
        <%= time_ago_in_words(recipe.created_at) %> ago
      </time>
    </div>
  </div>
</div>
