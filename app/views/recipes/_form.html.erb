<%= form_with model: recipe, local: false,
    data: {
      turbo: true,
      controller: "recipe-form",
      recipe_form_steps_target: "container"
    },
    multipart: true,
    class: "space-y-8" do |form| %>

  <!-- Error Messages -->
  <% if recipe.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            There were <%= pluralize(recipe.errors.count, "error") %> with your submission:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% recipe.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Basic Recipe Information -->
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-6">Basic Information</h2>

    <div class="grid grid-cols-1 gap-6">
      <!-- Recipe Title -->
      <div>
        <%= form.label :title, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :title,
            placeholder: "Enter a delicious recipe name...",
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 #{'border-red-300' if recipe.errors[:title].any?}" %>
        <% if recipe.errors[:title].any? %>
          <p class="mt-1 text-sm text-red-600"><%= recipe.errors[:title].first %></p>
        <% end %>
      </div>

      <!-- Recipe Description -->
      <div>
        <%= form.label :description, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_area :description,
            rows: 3,
            placeholder: "Describe your recipe...",
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 #{'border-red-300' if recipe.errors[:description].any?}" %>
        <% if recipe.errors[:description].any? %>
          <p class="mt-1 text-sm text-red-600"><%= recipe.errors[:description].first %></p>
        <% end %>
      </div>

      <!-- Recipe Image -->
      <div>
        <%= form.label :image, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1 flex items-center space-x-4">
          <% if recipe.persisted? && recipe.image.attached? %>
            <div class="flex-shrink-0">
              <%= image_tag recipe.image, class: "h-20 w-20 object-cover rounded-lg" %>
            </div>
          <% end %>
          <div class="flex-1">
            <%= form.file_field :image,
                accept: "image/*",
                class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
            <p class="mt-1 text-xs text-gray-500">PNG, JPG, GIF up to 10MB</p>
          </div>
        </div>
      </div>

      <!-- Recipe Details Grid -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div>
          <%= form.label :prep_time, "Prep Time (minutes)", class: "block text-sm font-medium text-gray-700" %>
          <%= form.number_field :prep_time,
              min: 1,
              placeholder: "15",
              class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 #{'border-red-300' if recipe.errors[:prep_time].any?}" %>
          <% if recipe.errors[:prep_time].any? %>
            <p class="mt-1 text-sm text-red-600"><%= recipe.errors[:prep_time].first %></p>
          <% end %>
        </div>

        <div>
          <%= form.label :cook_time, "Cook Time (minutes)", class: "block text-sm font-medium text-gray-700" %>
          <%= form.number_field :cook_time,
              min: 1,
              placeholder: "30",
              class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 #{'border-red-300' if recipe.errors[:cook_time].any?}" %>
          <% if recipe.errors[:cook_time].any? %>
            <p class="mt-1 text-sm text-red-600"><%= recipe.errors[:cook_time].first %></p>
          <% end %>
        </div>

        <div>
          <%= form.label :servings, class: "block text-sm font-medium text-gray-700" %>
          <%= form.number_field :servings,
              min: 1,
              placeholder: "4",
              class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 #{'border-red-300' if recipe.errors[:servings].any?}" %>
          <% if recipe.errors[:servings].any? %>
            <p class="mt-1 text-sm text-red-600"><%= recipe.errors[:servings].first %></p>
          <% end %>
        </div>

        <div>
          <%= form.label :difficulty_level, "Difficulty", class: "block text-sm font-medium text-gray-700" %>
          <%= form.select :difficulty_level,
              options_for_select([
                ['Easy', 'easy'],
                ['Medium', 'medium'],
                ['Hard', 'hard']
              ], recipe.difficulty_level),
              { prompt: 'Select difficulty' },
              { class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 #{'border-red-300' if recipe.errors[:difficulty_level].any?}" } %>
          <% if recipe.errors[:difficulty_level].any? %>
            <p class="mt-1 text-sm text-red-600"><%= recipe.errors[:difficulty_level].first %></p>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Recipe Steps -->
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6"
       data-controller="nested-form"
       data-nested-form-wrapper-selector-value=".recipe-step-fields">

    <div class="flex items-center justify-between mb-6">
      <h2 class="text-lg font-semibold text-gray-900">Cooking Instructions</h2>
      <button type="button"
              data-action="click->nested-form#add"
              class="inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-indigo-700 bg-indigo-100 hover:bg-indigo-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Add Step
      </button>
    </div>

    <div data-nested-form-target="container">
      <%= form.fields_for :recipe_steps do |step_form| %>
        <%= render 'recipe_step_fields', form: step_form %>
      <% end %>
    </div>

    <!-- Template for new steps -->
    <template data-nested-form-target="template">
      <%= form.fields_for :recipe_steps, RecipeStep.new, child_index: 'NEW_RECORD' do |step_form| %>
        <%= render 'recipe_step_fields', form: step_form %>
      <% end %>
    </template>
  </div>

  <!-- Form Actions -->
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <div class="flex items-center justify-between">
      <div class="flex space-x-3">
        <%= link_to recipes_path,
            class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
          Cancel
        <% end %>
      </div>

      <div class="flex space-x-3">
        <% if recipe.persisted? %>
          <%= link_to recipe_path(recipe),
              class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
            Preview
          <% end %>
        <% end %>

        <%= form.submit recipe.persisted? ? 'Update Recipe' : 'Create Recipe',
            class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500",
            data: { disable_with: "#{recipe.persisted? ? 'Updating' : 'Creating'}..." } %>
      </div>
    </div>
  </div>
<% end %>
