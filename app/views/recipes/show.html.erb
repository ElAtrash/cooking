<div class="min-h-screen bg-gray-50">
  <!-- Flash Messages -->
  <div id="flash_messages">
    <%= render 'shared/flash_messages' if notice || alert %>
  </div>

  <!-- Breadcrumb -->
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <nav class="flex" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-4">
          <li>
            <%= link_to recipes_path, class: "text-gray-400 hover:text-gray-500" do %>
              <svg class="flex-shrink-0 h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z" />
              </svg>
              <span class="sr-only">Home</span>
            <% end %>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="flex-shrink-0 h-5 w-5 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
              </svg>
              <%= link_to "Recipes", recipes_path, class: "ml-4 text-sm font-medium text-gray-500 hover:text-gray-700" %>
            </div>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="flex-shrink-0 h-5 w-5 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="ml-4 text-sm font-medium text-gray-500" aria-current="page">
                <%= truncate(@recipe.title, length: 30) %>
              </span>
            </div>
          </li>
        </ol>
      </nav>
    </div>
  </div>

  <!-- Recipe Header -->
  <div class="bg-white shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="lg:flex lg:items-start lg:space-x-8">

        <!-- Recipe Image -->
        <div class="lg:w-1/2">
          <div class="aspect-w-16 aspect-h-9 rounded-lg overflow-hidden">
            <% if @recipe.image.attached? %>
              <%= image_tag @recipe.image,
                  class: "w-full h-96 object-cover rounded-lg",
                  alt: @recipe.title %>
            <% else %>
              <div class="w-full h-96 bg-gradient-to-br from-gray-100 to-gray-200 rounded-lg flex items-center justify-center">
                <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Recipe Info -->
        <div class="mt-6 lg:mt-0 lg:w-1/2">
          <!-- Title and Author -->
          <div class="flex items-start justify-between">
            <div>
              <h1 class="text-3xl font-bold text-gray-900"><%= @recipe.title %></h1>
              <p class="mt-2 text-lg text-gray-600">
                by <%= @recipe.user.email_address %>
              </p>
            </div>

            <!-- Favorite Button -->
            <% if current_user && current_user != @recipe.user %>
              <div id="favorite_button_<%= @recipe.id %>">
                <%= render 'shared/favorite_button', recipe: @recipe, favorited: @recipe.favorited_by?(current_user) %>
              </div>
            <% end %>
          </div>

          <!-- Description -->
          <p class="mt-4 text-gray-700 leading-relaxed">
            <%= @recipe.description %>
          </p>

          <!-- Recipe Meta Info -->
          <div class="mt-6 grid grid-cols-2 gap-4">
            <div class="bg-gray-50 rounded-lg p-4">
              <div class="flex items-center">
                <svg class="w-5 h-5 text-gray-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div>
                  <p class="text-sm font-medium text-gray-900">Total Time</p>
                  <p class="text-lg text-gray-600"><%= @recipe.total_time %> minutes</p>
                </div>
              </div>
            </div>

            <div class="bg-gray-50 rounded-lg p-4">
              <div class="flex items-center">
                <svg class="w-5 h-5 text-gray-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
                <div>
                  <p class="text-sm font-medium text-gray-900">Servings</p>
                  <p class="text-lg text-gray-600"><%= @recipe.servings %></p>
                </div>
              </div>
            </div>

            <div class="bg-gray-50 rounded-lg p-4">
              <div class="flex items-center">
                <svg class="w-5 h-5 text-gray-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
                <div>
                  <p class="text-sm font-medium text-gray-900">Difficulty</p>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= @recipe.difficulty_badge_class %>">
                    <%= @recipe.difficulty_level.capitalize %>
                  </span>
                </div>
              </div>
            </div>

            <div class="bg-gray-50 rounded-lg p-4">
              <div class="flex items-center">
                <svg class="w-5 h-5 text-gray-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                </svg>
                <div>
                  <p class="text-sm font-medium text-gray-900">Rating</p>
                  <div class="flex items-center">
                    <% if @recipe.recipe_ratings_count > 0 %>
                      <span class="text-lg text-gray-600"><%= @recipe.average_rating %></span>
                      <span class="text-sm text-gray-500 ml-1">(<%= @recipe.recipe_ratings_count %>)</span>
                    <% else %>
                      <span class="text-sm text-gray-500">No ratings</span>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Action Buttons -->
          <% if current_user == @recipe.user %>
            <div class="mt-6 flex space-x-3">
              <%= link_to edit_recipe_path(@recipe),
                  class: "flex-1 bg-indigo-600 text-white text-center px-4 py-2 rounded-md hover:bg-indigo-700 transition-colors" do %>
                <svg class="w-4 h-4 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
                Edit Recipe
              <% end %>

              <%= link_to recipe_path(@recipe),
                  method: :delete,
                  data: {
                    confirm: "Are you sure you want to delete this recipe?",
                    turbo_method: :delete
                  },
                  class: "bg-red-600 text-white px-4 py-2 rounded-md hover:bg-red-700 transition-colors" do %>
                <svg class="w-4 h-4 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
                Delete
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Recipe Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="lg:grid lg:grid-cols-3 lg:gap-8">

      <!-- Ingredients -->
      <div class="lg:col-span-1">
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
          <h2 class="text-xl font-semibold text-gray-900 mb-4">Ingredients</h2>

          <% if @ingredients.any? %>
            <ul class="space-y-3">
              <% @ingredients.each do |recipe_ingredient| %>
                <li class="flex items-start">
                  <div class="flex-shrink-0 w-6 h-6 mt-0.5">
                    <div class="w-full h-full rounded border-2 border-gray-300"></div>
                  </div>
                  <div class="ml-3">
                    <span class="text-gray-900">
                      <%= recipe_ingredient.full_description %>
                    </span>
                    <% if recipe_ingredient.ingredient.category %>
                      <span class="inline-flex items-center px-2 py-1 ml-2 rounded-full text-xs font-medium <%= recipe_ingredient.ingredient.category_badge_class %>">
                        <%= recipe_ingredient.ingredient.category %>
                      </span>
                    <% end %>
                  </div>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="text-gray-500 italic">No ingredients listed yet.</p>
          <% end %>
        </div>
      </div>

      <!-- Instructions -->
      <div class="mt-8 lg:mt-0 lg:col-span-2">
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
          <h2 class="text-xl font-semibold text-gray-900 mb-6">Instructions</h2>

          <% if @steps.any? %>
            <div class="space-y-6">
              <% @steps.each do |step| %>
                <div class="flex">
                  <div class="flex-shrink-0">
                    <div class="flex items-center justify-center w-8 h-8 bg-indigo-600 text-white rounded-full text-sm font-medium">
                      <%= step.step_number %>
                    </div>
                  </div>
                  <div class="ml-4 flex-1">
                    <p class="text-gray-900 leading-relaxed">
                      <%= step.instruction %>
                    </p>
                    <% if step.has_image? %>
                      <div class="mt-3">
                        <%= image_tag step.image,
                            class: "w-full max-w-md h-48 object-cover rounded-lg",
                            alt: "Step #{step.step_number}" %>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-gray-500 italic">No instructions provided yet.</p>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Ratings Section -->
    <div class="mt-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-6">Ratings & Reviews</h2>

        <!-- Add Rating Form (if user is authenticated and doesn't own recipe) -->
        <% if current_user && current_user != @recipe.user && !@user_rating %>
          <div class="mb-6 p-4 bg-gray-50 rounded-lg">
            <h3 class="text-lg font-medium text-gray-900 mb-3">Rate this recipe</h3>
            <%= form_with model: [@recipe, @new_rating], local: false,
                data: { turbo: true }, class: "space-y-4" do |form| %>

              <div>
                <%= form.label :rating, class: "block text-sm font-medium text-gray-700" %>
                <div class="mt-1 flex items-center space-x-1" data-controller="rating" data-rating-target="stars">
                  <% (1..5).each do |star| %>
                    <button type="button"
                            class="text-gray-300 hover:text-yellow-400 focus:text-yellow-400 transition-colors"
                            data-action="click->rating#selectRating"
                            data-rating-value="<%= star %>">
                      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                      </svg>
                    </button>
                  <% end %>
                </div>
                <%= form.hidden_field :rating, data: { rating_target: "ratingInput" } %>
              </div>

              <div>
                <%= form.label :comment, class: "block text-sm font-medium text-gray-700" %>
                <%= form.text_area :comment,
                    rows: 3,
                    placeholder: "Share your thoughts about this recipe...",
                    class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
              </div>

              <div>
                <%= form.submit "Submit Rating",
                    class: "bg-indigo-600 text-white px-4 py-2 rounded-md hover:bg-indigo-700 transition-colors" %>
              </div>
            <% end %>
          </div>
        <% end %>

        <!-- Existing Ratings -->
        <% if @ratings.any? %>
          <div class="space-y-4">
            <% @ratings.each do |rating| %>
              <div class="border-b border-gray-200 pb-4 last:border-b-0">
                <div class="flex items-start justify-between">
                  <div class="flex items-center">
                    <div class="flex items-center">
                      <% (1..5).each do |star| %>
                        <svg class="w-4 h-4 <%= rating.rating >= star ? 'text-yellow-400' : 'text-gray-300' %>"
                             fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                      <% end %>
                    </div>
                    <span class="ml-2 text-sm font-medium text-gray-900">
                      <%= rating.user.name || rating.user.email %>
                    </span>
                  </div>
                  <time class="text-sm text-gray-500" datetime="<%= rating.created_at.iso8601 %>">
                    <%= time_ago_in_words(rating.created_at) %> ago
                  </time>
                </div>
                <% if rating.has_comment? %>
                  <p class="mt-2 text-gray-700">
                    <%= rating.comment %>
                  </p>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-gray-500 italic">No ratings yet. Be the first to rate this recipe!</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
