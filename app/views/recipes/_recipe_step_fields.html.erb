<div class="recipe-step-fields border border-gray-200 rounded-lg p-4 mb-4 bg-gray-50"
     data-nested-form-target="item">

  <div class="flex items-start space-x-4">
    <!-- Step Number -->
    <div class="flex-shrink-0 mt-2">
      <div class="flex items-center justify-center w-8 h-8 bg-indigo-600 text-white rounded-full text-sm font-medium">
        <span data-step-number>
          <%= form.object&.step_number || (form.index ? form.index + 1 : 'NEW') %>
        </span>
      </div>
    </div>

    <!-- Step Content -->
    <div class="flex-1 space-y-4">
      <!-- Hidden step number field -->
      <%= form.hidden_field :step_number %>

      <!-- Instruction Field -->
      <div>
        <%= form.label :instruction, "Instruction", class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_area :instruction,
            rows: 3,
            placeholder: "Describe this cooking step in detail...",
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>

      <!-- Step Image -->
      <div>
        <%= form.label :image, "Step Image (optional)", class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1 flex items-center space-x-4">
          <% if form.object&.persisted? && form.object&.image&.attached? %>
            <div class="flex-shrink-0">
              <%= image_tag form.object.image, class: "h-16 w-16 object-cover rounded-lg" %>
            </div>
          <% end %>
          <div class="flex-1">
            <%= form.file_field :image,
                accept: "image/*",
                class: "block w-full text-sm text-gray-500 file:mr-4 file:py-1 file:px-2 file:rounded file:border-0 file:text-xs file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex items-center justify-between pt-2">
        <div class="flex items-center space-x-2">
          <!-- Move Up Button -->
          <button type="button"
                  data-action="click->nested-form#moveUp"
                  class="inline-flex items-center p-1 border border-transparent rounded text-gray-400 hover:text-gray-600 focus:outline-none focus:text-gray-600"
                  title="Move step up">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5-5m0 0l5 5m-5-5v12" />
            </svg>
          </button>

          <!-- Move Down Button -->
          <button type="button"
                  data-action="click->nested-form#moveDown"
                  class="inline-flex items-center p-1 border border-transparent rounded text-gray-400 hover:text-gray-600 focus:outline-none focus:text-gray-600"
                  title="Move step down">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 13l-5 5m0 0l-5-5m5 5V6" />
            </svg>
          </button>
        </div>

        <!-- Remove Step Button -->
        <button type="button"
                data-action="click->nested-form#remove"
                class="inline-flex items-center px-2 py-1 border border-transparent text-xs font-medium rounded text-red-700 bg-red-100 hover:bg-red-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
          <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
          Remove
        </button>
      </div>

      <!-- Hidden field for deletion -->
      <% if form.object&.persisted? %>
        <%= form.hidden_field :_destroy %>
      <% end %>
    </div>
  </div>
</div>
