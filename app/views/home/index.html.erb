<div class="min-h-screen bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="py-6">
      <div class="flex justify-between items-center">
        <h1 class="text-2xl font-bold text-gray-900"><%= Rails.application.class.module_parent_name %></h1>
        <nav class="space-x-4">
          <% if current_user %>
            <span class="text-gray-600">Welcome, <%= current_user.email_address %></span>
            <%= link_to "Sign out", session_path, method: :delete, class: "bg-red-600 text-white px-4 py-2 rounded-md hover:bg-red-700" %>
          <% else %>
            <%= link_to "Sign in", new_session_path, class: "bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700" %>
          <% end %>
        </nav>
      </div>
    </header>

    <!-- Main content -->
    <main class="py-12">
      <div class="text-center">
        <h2 class="text-4xl font-bold text-gray-900 mb-8">Welcome to Your Rails 8 Starter Pack</h2>
        <p class="text-xl text-gray-600 mb-12 max-w-3xl mx-auto">
          Your application is ready to go with authentication, testing, styling, and all the tools you need to build something amazing.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
          <!-- Feature cards -->
          <div class="bg-white rounded-lg shadow p-6">
            <div class="text-green-600 mb-4">
              <svg class="w-8 h-8 mx-auto" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Authentication Ready</h3>
            <p class="text-gray-600">Rails 8 built-in authentication with secure sessions and password management.</p>
          </div>

          <div class="bg-white rounded-lg shadow p-6">
            <div class="text-blue-600 mb-4">
              <svg class="w-8 h-8 mx-auto" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Testing Suite</h3>
            <p class="text-gray-600">RSpec with FactoryBot and Faker for comprehensive testing.</p>
          </div>

          <div class="bg-white rounded-lg shadow p-6">
            <div class="text-purple-600 mb-4">
              <svg class="w-8 h-8 mx-auto" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zm0 4a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1V8zm8 0a1 1 0 011-1h6a1 1 0 011 1v2a1 1 0 01-1 1h-6a1 1 0 01-1-1V8zm0 4a1 1 0 011-1h6a1 1 0 011 1v2a1 1 0 01-1 1h-6a1 1 0 01-1-1v-2z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Modern Frontend</h3>
            <p class="text-gray-600">Tailwind CSS, Turbo, and Stimulus for responsive, interactive UIs.</p>
          </div>
        </div>

        <div class="mt-12">
          <% unless current_user %>
            <p class="text-gray-600 mb-4">Try signing in with these test accounts:</p>
            <div class="bg-white rounded-lg shadow p-6 max-w-md mx-auto">
              <div class="space-y-2 text-sm">
                <p><strong>Admin:</strong> admin@example.com</p>
                <p><strong>User:</strong> user@example.com</p>
                <p><strong>Password:</strong> password123</p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </main>
  </div>
</div>
